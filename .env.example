# Mapbox public token used by the frontend only (map rendering).
# Use a public token (pk.) with URL/origin restrictions configured in Mapbox.
MAPBOX_TOKEN=pk.your-public-mapbox-token

# Session/auth configuration
# APP_SESSION_SECRET should be a long random string used to sign login cookies.
APP_SESSION_SECRET=replace-with-long-random-secret
# OWNER_PASSWORD_HASH should be generated from your chosen password using pwdlib Argon2.
# Example:
#   python -c "from pwdlib import PasswordHash; print(PasswordHash.recommended().hash('replace-me'))"
OWNER_PASSWORD_HASH=
# Explicit origins/hosts allowed to send credentialed requests to the app.
CORS_ALLOWED_ORIGINS=https://www.everystreet.me,http://localhost:8080,http://127.0.0.1:8080
ALLOWED_HOSTS=www.everystreet.me,everystreet.me,localhost,127.0.0.1

# Optional: Geofabrik mirror and OSM extracts path (inside containers)
# GEOFABRIK_MIRROR=https://download.geofabrik.de
# OSM_EXTRACTS_PATH=/osm
# Optional: OSM extract used by coverage ingestion (defaults to coverage extract)
# OSM_DATA_PATH=/osm/coverage/coverage.osm.pbf
# Optional: size (MB) at which to build a per-area extract before graphing
# OSM_AREA_EXTRACT_THRESHOLD_MB=1024

# Docker Compose project name (used for container discovery)
COMPOSE_PROJECT_NAME=everystreet

# Docker image for web/worker (GHCR default for auto-updates)
# EVERYSTREET_IMAGE=ghcr.io/realronaldrump/everystreet-new:main

# Watchtower updates are enabled by default in docker-compose.yml
# Set a strong random token (required by scripts/prod-up.sh).
WATCHTOWER_TOKEN=replace-with-long-random-token

# Optional: Cloudflare named tunnel token if you decide to run the main app
# ingress through a repo-managed cloudflared container.
# CLOUDFLARED_TUNNEL_TOKEN=

# Geo build tuning (lower threads if you see OOM)
NOMINATIM_IMPORT_THREADS=2
# Optional extra args for valhalla_build_tiles (advanced)
# VALHALLA_BUILD_TILES_ARGS=--concurrency 1

# Optional: trip fetch job timeout in seconds (default 900)
# TRIP_FETCH_JOB_TIMEOUT_SECONDS=900

# Optional: map data job stall detection thresholds (minutes)
# MAP_DATA_JOB_STALLED_RUNNING_MINUTES=20
# MAP_DATA_JOB_STALLED_PENDING_MINUTES=30

# Optional timezone (defaults to system time)
# TZ=America/Chicago

# =============================================================================
# Database Configuration
# =============================================================================
# MongoDB database name (optional)
# MONGODB_DATABASE=every_street
