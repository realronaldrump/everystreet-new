[run]
source = .
omit =
    .autofix/*
    .claude/*
    .codex/*
    .cursor/*
    .git/*
    .github/*
    .pytest_cache/*
    .ruff_cache/*
    .vscode/*
    node_modules/*
    pytest-of-*/*
    scripts/*
    tests/*
    venv/*
    */__pycache__/*
    */site-packages/*

[report]
skip_empty = true
